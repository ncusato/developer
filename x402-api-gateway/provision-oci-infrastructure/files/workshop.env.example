# Copy this file to workshop.env and edit the values before running the lab scripts.
# Use Oracle Cloud Shell for the 60-minute workshop path.

export COMPARTMENT_OCID="ocid1.compartment.oc1..replace-with-your-compartment-ocid"
export REGION="us-ashburn-1"
export REGION_KEY="iad"
export TENANCY_NAMESPACE="replace-with-your-tenancy-namespace"

export WORKSHOP_PREFIX="x402"
export VCN_NAME="x402-workshop-vcn"
export PUBLIC_SUBNET_NAME="x402-public-subnet"
export PRIVATE_SUBNET_NAME="x402-private-subnet"
export API_GATEWAY_NAME="x402-api-gateway"
export FUNCTIONS_APP_NAME="x402-functions"
export ADB_DISPLAY_NAME="x402-monetized-db"
export ADB_DB_NAME="x402db"
export ADB_ADMIN_PASSWORD="ReplaceWithStrongPassword#2026"
# Optional: set this to reuse an existing Autonomous Database instead of creating a new Always Free database.
export ADB_OCID=""
# Optional paid fallback. Set to true only if you accept creating a billable Autonomous Database when Always Free quota is unavailable.
export ADB_ALLOW_PAID_FALLBACK="false"
export ADB_PAID_COMPUTE_COUNT="4"
export ADB_PAID_STORAGE_GBS="20"
export ADB_DB_VERSION="19c"
export SH_PASSWORD="ReplaceWithStrongShPassword#2026"
export X402_APP_PASSWORD="ReplaceWithStrongX402Password#2026"

export PAY_TO_ADDRESS="0xYourTestWalletAddress"
export FACILITATOR_URL="https://x402.org/facilitator"
export NETWORK="eip155:84532"
export ASSET_ADDRESS="0x036CbD53842c5426634e7929541eC2318f3dCF7e"
export USDC_EIP712_NAME="USDC"
export USDC_EIP712_VERSION="2"

# Published workshop file base. Override this if you are testing from a fork or branch.
export WORKSHOP_FILES_BASE="https://raw.githubusercontent.com/oracle-livelabs/developer/main/x402-api-gateway"
